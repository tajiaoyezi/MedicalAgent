# 公网 / 私有化双入口：无公网时仅配置内网地址即可启动
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
SESSION_SECRET=change-me-in-production-use-long-random-string

# PostgreSQL（私有化 / 内网）
DATABASE_URL=postgres://medoffice:medoffice@localhost:5432/medoffice

# 对象存储 — MinIO（默认，完全离线可用）
STORAGE_BACKEND=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=medoffice
MINIO_REGION=us-east-1

# 对象存储 — S3 兼容（可选，设置 STORAGE_BACKEND=s3）
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=medoffice
# S3_REGION=us-east-1

# 前端开发代理
WEB_ORIGIN=http://localhost:5173

# ONLYOFFICE Document Server（私有化部署，无公网外呼）
ONLYOFFICE_DS_URL=http://localhost:8080
ONLYOFFICE_JWT_ENABLED=true
ONLYOFFICE_JWT_SECRET=dev-local-onlyoffice-jwt-do-not-deploy
# DS 容器回调业务 API 时使用（Windows Docker Desktop 用 host.docker.internal）
API_PUBLIC_URL=http://host.docker.internal:3001
ONLYOFFICE_PLUGIN_URL=http://host.docker.internal:5173/onlyoffice-plugin/
# 编辑器会话：callback/bridge 续期 TTL（秒，默认 2h）
EDITOR_CALLBACK_TTL=7200
