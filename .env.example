# 公网 / 私有化双入口：无公网时仅配置内网地址即可启动
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
SESSION_SECRET=change-me-in-production-use-long-random-string

# PostgreSQL（私有化 / 内网）
DATABASE_URL=postgres://medoffice:medoffice@localhost:5432/medoffice

# 对象存储 — MinIO（默认，完全离线可用）
STORAGE_BACKEND=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=medoffice
MINIO_REGION=us-east-1

# 对象存储 — S3 兼容（可选，设置 STORAGE_BACKEND=s3）
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=medoffice
# S3_REGION=us-east-1

# 前端开发代理
WEB_ORIGIN=http://localhost:5173
