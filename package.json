{
  "name": "medoffice-ai",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:api": "cd apps/server && go run ./cmd/server",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build:api && npm run build:web",
    "build:api": "cd apps/server && go build ./...",
    "build:web": "npm run build --workspace=apps/web",
    "migrate": "cd apps/server && go run ./cmd/migrate",
    "smoke": "cd apps/server && go run ./cmd/smoke/infra",
    "smoke:integration": "cd apps/server && go run ./cmd/smoke/integration",
    "smoke:authz": "cd apps/server && go run ./cmd/smoke/authz",
    "smoke:onlyoffice": "cd apps/server && go run ./cmd/smoke/onlyoffice",
    "smoke:editor-authz": "cd apps/server && go run ./cmd/smoke/editor_authz",
    "smoke:c03": "cd apps/server && go run ./cmd/smoke/c03",
    "smoke:c04": "cd apps/server && go run ./cmd/smoke/c04",
    "smoke:c05": "cd apps/server && go run ./cmd/smoke/c05",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report e2e/.report",
    "typecheck:e2e": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "typescript": "^5.9.3"
  }
}
